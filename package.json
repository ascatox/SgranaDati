{
  "name": "sgranadati",
  "version": "0.1.4",
  "description": "Desktop app locale per anonimizzare documenti prima di inviarli a sistemi AI.",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "check": "node -e \"console.log('ok')\"",
    "dist:win": "electron-builder --win nsis --publish never",
    "dist:win:release": "electron-builder --win nsis --publish always",
    "dist:mac": "electron-builder --mac dmg zip --publish never",
    "dist:mac:release": "electron-builder --mac dmg zip --publish always",
    "dist:win-portable": "electron-builder --win portable --publish never",
    "dist:dir": "electron-builder --dir --publish never"
  },
  "keywords": [
    "electron",
    "privacy",
    "pii",
    "anonymization",
    "desktop"
  ],
  "author": "",
  "license": "MIT",
  "productName": "SgranaDati",
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5"
  },
  "build": {
    "appId": "it.ascatox.sgranadati",
    "productName": "SgranaDati",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "package.json",
      "package-lock.json",
      "!node_modules/.cache/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "SgranaDati-${version}-setup-${arch}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "SgranaDati-${version}-${arch}.${ext}",
      "category": "public.app-category.productivity"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "SgranaDati-${version}-setup-${arch}.${ext}",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SgranaDati"
    },
    "portable": {
      "artifactName": "SgranaDati-${version}-portable-${arch}.${ext}"
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  }
}
